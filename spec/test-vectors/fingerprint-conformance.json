      "test_id": "T-PHAEDO-FP-GOOD-0013",
      "description": "§4.7 conflict_records resolution.by:'user' after revert — carries ack_at + reverted_to so the audit trail shows when and to what the subject restored. Candidates carry both sides (self-report + observed) — a realistic shape a producer would actually emit (popup.js revertOverride / mobile revertOverride preserve them from the staged record).",
      "doc": {
        "phaedo_fingerprint": {
          "phaedo_protocol_version": "0.1",
          "subject_id": "s",
          "schema_revision": 1,
          "layers": { "surface": { "signals": [] } },
