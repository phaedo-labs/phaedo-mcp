    {
      "test_id": "T-PHAEDO-FP-GOOD-0012",
      "description": "§4.7 conflict_records resolution.by:'system' — a sustained behavioral override of a self-report, surfaced for review. Both sides carried (chosen_value + prior_value) so the subject can acknowledge or revert.",
      "doc": {
        "phaedo_fingerprint": {
          "phaedo_protocol_version": "0.1",
          "subject_id": "s",
          "schema_revision": 1,
          "layers": {
            "surface": {
              "signals": [
                { "field": "response_length_pref", "polarity": "positive", "value": "short", "confidence": 0.85, "evidence_basis": "observed", "observation_count": 7 }
              ]
            }
          },
          "conflict_records": [
            {
              "conflict_id": "11111111-1111-4111-8111-111111111111",
              "layer": "surface",
              "field": "response_length_pref",
              "status": "resolved",
              "detected_at": "2026-06-29T00:00:00Z",
              "last_seen": "2026-06-29T12:00:00Z",
              "resolved_at": "2026-06-29T12:00:00Z",
              "candidates": [
                { "value": "thorough", "source": "questionnaire", "evidence_basis": "self_reported", "confidence": 0.7, "observation_count": 1, "last_observed": "2026-06-01T00:00:00Z" },
                { "value": "short",    "source": "extraction",    "evidence_basis": "observed",      "confidence": 0.85, "observation_count": 7, "last_observed": "2026-06-29T00:00:00Z" }
              ],
              "resolution": { "chosen_value": "short", "prior_value": "thorough", "by": "system" }
            }
          ]
        }
      },
      "expect": "pass"
    },
