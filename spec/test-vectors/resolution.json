{
  "category": "TC-RESOLVE",
  "describes": "Proposal 0006 — deterministic conflict resolution (Route A: evidence-tier precedence, recency tiebreak, ≥3 minimum-evidence floor → status:unresolved). resolveDimension(signals) over one dimension's signals.",
  "vectors": [
    {
      "test_id": "R-RESOLVE-0001",
      "description": "Single signal resolves to itself.",
      "signals": [
        { "field": "autonomy", "polarity": "positive", "value": "execute", "evidence_basis": "observed", "observation_count": 4, "last_observed": "2026-06-10" }
      ],
      "expect": { "value": "execute", "status": "resolved" }
    },
    {
      "test_id": "R-RESOLVE-0002",
      "description": "Established observed (>=3) overrides self_reported on a value conflict.",
      "signals": [
        { "field": "autonomy", "polarity": "positive", "value": "check before acting", "evidence_basis": "self_reported", "observation_count": 1, "last_observed": "2026-06-01" },
        { "field": "autonomy", "polarity": "positive", "value": "execute without dialogue", "evidence_basis": "observed", "observation_count": 5, "last_observed": "2026-06-12" }
      ],
      "expect": { "value": "execute without dialogue", "status": "resolved" }
    },
    {
      "test_id": "R-RESOLVE-0003",
      "description": "THE AUTONOMY CASE: thin observed (<3) does NOT override the interview value — conflict resolves to unresolved (consumer treats conservatively).",
      "signals": [
        { "field": "autonomy", "polarity": "positive", "value": "check before acting", "evidence_basis": "self_reported", "observation_count": 1, "last_observed": "2026-06-01" },
        { "field": "autonomy", "polarity": "positive", "value": "execute without dialogue", "evidence_basis": "observed", "observation_count": 2, "last_observed": "2026-06-12" }
      ],
      "expect": { "status": "unresolved" }
    },
    {
      "test_id": "R-RESOLVE-0004",
      "description": "Two observed signals conflict → higher observation_count wins (recency would break a further tie).",
      "signals": [
        { "field": "speed", "value": "fast", "evidence_basis": "observed", "observation_count": 2, "last_observed": "2026-06-05" },
        { "field": "speed", "value": "thorough", "evidence_basis": "observed", "observation_count": 6, "last_observed": "2026-06-04" }
      ],
      "expect": { "value": "thorough", "status": "resolved" }
    },
    {
      "test_id": "R-RESOLVE-0005",
      "description": "Agreement across sources (same value) is not a conflict → resolved.",
      "signals": [
        { "field": "directness", "value": "high", "evidence_basis": "self_reported", "observation_count": 1 },
        { "field": "directness", "value": "high", "evidence_basis": "observed", "observation_count": 4 }
      ],
      "expect": { "value": "high", "status": "resolved" }
    },
    {
      "test_id": "R-RESOLVE-0006",
      "description": "Corroborated outranks observed regardless of observation_count.",
      "signals": [
        { "field": "tone", "value": "warm", "evidence_basis": "observed", "observation_count": 10, "last_observed": "2026-06-10" },
        { "field": "tone", "value": "direct", "evidence_basis": "corroborated", "observation_count": 4, "last_observed": "2026-06-09" }
      ],
      "expect": { "value": "direct", "status": "resolved" }
    }
  ]
}
