{
  "name": "phaedo-mcp",
  "version": "0.2.1",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Phaedo MCP server — inject your cognitive fingerprint into any MCP client, and consult your decision pattern at agent decision points (docs/protocol/mcp-binding.md).",
  "mcpName": "io.github.phaedo-labs/phaedo-mcp",
  "homepage": "https://phaedo.so",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaedo-labs/phaedo.git",
    "directory": "mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "personalization",
    "fingerprint",
    "consultation",
    "agent"
  ],
  "bin": {
    "phaedo-mcp": "server.js"
  },
  "files": [
    "server.js",
    "server.json",
    "fingerprint-source.js",
    "projection.js",
    "errors.js",
    "consult.js",
    "consult-core.js",
    "consult-policy.js",
    "receipts.js",
    "agreement.js",
    "calibration.js",
    "phone-source.js",
    "cache.js",
    "pairing.js",
    "pair.js",
    "pull.js",
    "install.mjs",
    "build-package.mjs",
    "vendor/",
    "lib/",
    "hooks/",
    "installers/",
    "policy-editor.html",
    "sample-fingerprint.json",
    "pairing.sample.json",
    "consult-policies.sample.json",
    "README.md"
  ],
  "scripts": {
    "start": "node server.js",
    "build": "node build-package.mjs",
    "prepack": "node build-package.mjs",
    "pretest": "node build-package.mjs",
    "setup": "node install.mjs",
    "setup:pair": "node install.mjs --pair",
    "setup:code-hook": "node install.mjs --code-hook",
    "unsetup": "node install.mjs --uninstall",
    "pair": "node pair.js",
    "pull": "node pull.js",
    "test": "node test-smoke.mjs && node test-phone-boundary.mjs && node test-cache.mjs && node test-pairing.mjs && node test-revoke.mjs && node test-install.mjs && node test-consult.mjs && node test-consult-policy.mjs && node test-delegation-sync.mjs && node test-delegation-relay.mjs && node test-escalation.mjs && node test-receipts.mjs && node test-receipts-sync.mjs && node test-agreement.mjs && node test-calibration.mjs && node test-identity.mjs",
    "receipts": "node receipts.js list",
    "agreement": "node agreement.js",
    "calibration": "node calibration.js",
    "health": "node health.js",
    "validate": "node ../spec/validate-fingerprint.mjs sample-fingerprint.json",
    "smoke": "node test-smoke.mjs",
    "smoke:phone": "node test-phone-boundary.mjs",
    "smoke:cache": "node test-cache.mjs",
    "smoke:pair": "node test-pairing.mjs",
    "smoke:revoke": "node test-revoke.mjs",
    "smoke:install": "node test-install.mjs",
    "smoke:consult": "node test-consult.mjs",
    "smoke:policy": "node test-consult-policy.mjs",
    "smoke:escalation": "node test-escalation.mjs",
    "smoke:receipts": "node test-receipts.mjs",
    "smoke:agreement": "node test-agreement.mjs",
    "smoke:calibration": "node test-calibration.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  }
}
